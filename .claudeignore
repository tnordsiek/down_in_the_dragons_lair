# Dependencies — kein relevanter Quellcode, massiv groß
node_modules/

# Build-Artefakte — abgeleitet aus src/, nicht bearbeiten
dist/
coverage/
playwright-report/
test-results/

# Vite/Tool-Caches
.vite/
.cache/

# Binary Assets — Claude kann PNGs/OGGs nicht sinnvoll lesen oder editieren
public/assets/sounds/
public/assets/**/*.png

# Git-Interna
.git/

# Generierte Artefakte — kein Quellcode, kein Mehrwert für Claude
package-lock.json
*.tsbuildinfo

# Claude-Konfiguration — Permissions-Allowlist, kein relevanter Code
.claude/settings.local.json

# Log-Dateien
*.log
npm-debug.log*
.vite-dev*.log

# Temporäre Dateien
*.tmp
*.bak
tmp/
temp/
