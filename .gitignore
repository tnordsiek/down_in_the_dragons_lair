# .gitignore — JavaScript/TypeScript-Projekt
#
# Zweck: typische umfangreiche oder generierte Verzeichnisse/Dateien ausschließen.
# Effekt: Claude Code UND OpenAI Codex respektieren .gitignore automatisch — ausgeschlossene
# Pfade tauchen nicht in Suchen/Dateilisten auf, das spart Tokens.

# === Kompilierte / ausführbare Artefakte ===
*.exe
*.dll
*.dylib
*.bin
*.msi
*.dmg
*.pkg

# === Node / JavaScript / TypeScript ===
node_modules/
dist/
build/
out/
.cache/
coverage/
*.tsbuildinfo
playwright-report/
test-results/

# Framework-Caches
.next/
.nuxt/
.svelte-kit/
.astro/
.vite/
.turbo/
.parcel-cache/

# Debug-Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite-dev*.log

# === Electron / Desktop-GUI-Builds ===
release/
dist_electron/

# === Umgebung / Secrets ===
.env
.env.*
!.env.example

# === Logs & temporäre Dateien ===
logs/
tmp/
temp/
*.tmp
*.bak

# === Betriebssystem ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor / IDE ===
# .vscode/ bei Bedarf selektiv versionieren (z. B. !.vscode/extensions.json)
.vscode/
.idea/
*.swp
*~

# === Claude Code / KI-Tool-Caches ===
.claude/.codex/jobs/

# === Generierte Artefakte (Root) ===
assets.manifest.json

# === Lokale Asset-Workfiles ===
assets/source/
assets/tmp/
