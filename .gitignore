# .gitignore — Vorlage für Python- und JavaScript/TypeScript-Projekte
#
# Zweck: typische umfangreiche oder generierte Verzeichnisse/Dateien ausschließen.
# Effekt: Claude Code UND OpenAI Codex respektieren .gitignore automatisch — ausgeschlossene
# Pfade tauchen nicht in Suchen/Dateilisten auf, das spart Tokens.
# Nutzung: diese Datei in das Wurzelverzeichnis des jeweiligen Projekts kopieren.

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtuelle Umgebungen (venv)
.venv/
venv/
env/
ENV/
.python-version

# Test-, Type- und Lint-Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/

# Coverage-Berichte
.coverage
.coverage.*
htmlcov/
coverage.xml

# Packaging / Build
build/
dist/
*.egg-info/
.eggs/
*.egg
wheels/

# Jupyter
.ipynb_checkpoints/

# === Standalone-Builds (PyInstaller / Nuitka / cx_Freeze) ===
# build/ und dist/ sind bereits oben abgedeckt (PyInstaller, cx_Freeze).
# Hinweis: PyInstaller-*.spec wird BEWUSST nicht ignoriert — klein, ist Konfiguration
# und sollte versioniert werden.
*.build/
*.dist/
*.onefile-build/

# === Kompilierte / ausführbare Artefakte ===
*.exe
*.dll
*.dylib
*.bin
*.msi
*.dmg
*.pkg

# === Node / JavaScript / TypeScript ===
node_modules/
dist/
build/
out/
.cache/
coverage/
*.tsbuildinfo
playwright-report/
test-results/

# Framework-Builds
.next/
.nuxt/
.svelte-kit/
.astro/
.vite/
.cache/
.turbo/
.parcel-cache/

# Debug-Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Electron / Desktop-GUI-Builds ===
release/
dist_electron/

# === Umgebung / Secrets ===
.env
.env.*
!.env.example

# === Logs & temporäre Dateien ===
*.log
logs/
tmp/
temp/
*.tmp

# === Betriebssystem ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor / IDE ===
# .vscode/ bei Bedarf selektiv versionieren (z. B. !.vscode/extensions.json)
.vscode/
.idea/
*.swp
*~

# === Claude Code / KI-Tool-Caches ===
# Job-History des Codex-Plugins (Logs, Status, Ergebnisse) — projektspezifisch, nicht versionieren
.claude/.codex/jobs/
# Local runtime / generated files
tmp/
temp/
*.tmp
*.bak

# Local asset workfiles
assets/source/
assets/tmp/
